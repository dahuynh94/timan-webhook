# ─── SePay ────────────────────────────────────────────────────────────────────
SEPAY_API_KEY=your_sepay_api_key
SEPAY_API_BASE=https://my.sepay.vn/userapi

# Webhook server (sepay_webhook.py)
# API key phải khớp với key cấu hình trong SePay dashboard → Webhook → API Key
SEPAY_WEBHOOK_API_KEY=your_sepay_webhook_api_key
# Secret dùng để verify HMAC-SHA256 signature (để trống nếu không dùng)
SEPAY_WEBHOOK_SECRET=your_webhook_secret
# Port chạy webhook server (mặc định 5055)
SEPAY_WEBHOOK_PORT=5055
# Danh sách IP của SePay (để trống = chấp nhận tất cả, chỉ filter khi có reverse proxy)
# SEPAY_IP_WHITELIST=103.88.44.10,103.88.44.11,103.88.44.12
# Log file (mặc định logs/sepay_webhook.log)
# FINANCE_WEBHOOK_LOG=logs/sepay_webhook.log

# ─── Google Sheets ────────────────────────────────────────────────────────────
# Path đến file credentials JSON tải từ Google Cloud Console
GOOGLE_CREDENTIALS_PATH=credentials/google_service_account.json
# ID của spreadsheet chứa báo cáo tiền mặt (lấy từ URL)
CASH_SHEET_ID=1BxiMVs0XRA5nFMdKvBdBZjgmUUqptlbs74OgVE2upms

# ─── Reconciliation thresholds ────────────────────────────────────────────────
# Sai lệch tối đa (VND) được chấp nhận là "matched" (phí, làm tròn)
FINANCE_MISMATCH_TOLERANCE=2000
# Sai lệch tiền mặt cửa hàng (VND) sẽ tạo cảnh báo
FINANCE_STORE_VARIANCE_THRESHOLD=50000
# Thanh toán ads tối thiểu (VND) để gắn cờ "unassigned"
FINANCE_ADS_UNASSIGNED_MIN=10000

